/bathroom-remodeling.webp" alt="Bathroom Remodel" width="800" height="450" loading="lazy" decoding="async" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" title="Bathroom Remodeling - Maverick City Builders"><div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent"></div><div class="absolute bottom-0 left-0 p-8 w-full"><h3 class="text-white font-heading text-2xl font-bold mb-2 drop-shadow-md">Bathroom Remodel</h3><div class="flex items-center gap-2 text-gray-300"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin h-5 w-5 text-[#E63946]" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path><circle cx="12" cy="10" r="3"></circle></svg><span class="font-medium drop-shadow-md">Berlin, MA</span></div></div></a></div></div></div></section><section class="py-32 bg-[#111] border-t border-white/5 relative z-20"><div class="container max-w-6xl"><div class="text-center mb-20"><h2 class="font-heading text-4xl md:text-5xl font-bold mb-6 text-white tracking-tight">Our Simple 4-Step Process</h2><p class="text-xl text-gray-400 font-light max-w-2xl mx-auto">We make home remodeling stress-free and transparent from day one.</p></div><div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative"><div class="hidden md:block absolute top-12 left-[10%] right-[10%] h-[2px] bg-gradient-to-r from-transparent via-[#E63946]/50 to-transparent z-0"></div><div class="relative z-10 flex flex-col items-center text-center"><div class="w-24 h-24 rounded-full bg-black border-4 border-[#111] shadow-[0_0_30px_rgba(230,57,70,0.2)] flex items-center justify-center text-[#E63946] mb-6 relative" aria-hidden="true"><div class="absolute inset-0 rounded-full border border-[#E63946]/30 animate-pulse"></div><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clipboard-list h-8 w-8"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"></rect><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><path d="M12 11h4"></path><path d="M12 16h4"></path><path d="M8 11h.01"></path><path d="M8 16h.01"></path></svg></div><h3 class="font-bold text-xl text-white mb-3 tracking-wide">1. Request Estimate</h3><p class="text-gray-400 font-light leading-relaxed">Contact us with your project details and goals.</p></div><div class="relative z-10 flex flex-col items-center text-center"><div class="w-24 h-24 rounded-full bg-black border-4 border-[#111] shadow-[0_0_30px_rgba(230,57,70,0.2)] flex items-center justify-center text-[#E63946] mb-6 relative" aria-hidden="true"><div class="absolute inset-0 rounded-full border border-[#E63946]/30 animate-pulse"></div><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-messages-square h-8 w-8"><path d="M14 9a2 2 0 0 1-2 2H6l-4 4V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2z"></path><path d="M18 9h2a2 2 0 0 1 2 2v11l-4-4h-6a2 2 0 0 1-2-2v-1"></path></svg></div><h3 class="font-bold text-xl text-white mb-3 tracking-wide">2. Consultation</h3><p class="text-gray-400 font-light leading-relaxed">We visit your home, discuss options, and provide a clear quote.</p></div><div class="relative z-10 flex flex-col items-center text-center"><div class="w-24 h-24 rounded-full bg-black border-4 border-[#111] shadow-[0_0_30px_rgba(230,57,70,0.2)] flex items-center justify-center text-[#E63946] mb-6 relative" aria-hidden="true"><div class="absolute inset-0 rounded-full border border-[#E63946]/30 animate-pulse"></div><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-pen-tool h-8 w-8"><path d="M15.707 21.293a1 1 0 0 1-1.414 0l-1.586-1.586a1 1 0 0 1 0-1.414l5.586-5.586a1 1 0 0 1 1.414 0l1.586 1.586a1 1 0 0 1 0 1.414z"></path><path d="m18 13-1.375-6.874a1 1 0 0 0-.746-.776L3.235 2.028a1 1 0 0 0-1.207 1.207L5.35 15.879a1 1 0 0 0 .776.746L13 18"></path><path d="m2.3 2.3 7.286 7.286"></path><circle cx="11" cy="11" r="2"></circle></svg></div><h3 class="font-bold text-xl text-white mb-3 tracking-wide">3. Project Planning</h3><p class="text-gray-400 font-light leading-relaxed">We finalize designs, order materials, and secure permits.</p></div><div class="relative z-10 flex flex-col items-center text-center"><div class="w-24 h-24 rounded-full bg-black border-4 border-[#111] shadow-[0_0_30px_rgba(230,57,70,0.2)] flex items-center justify-center text-[#E63946] mb-6 relative" aria-hidden="true"><div class="absolute inset-0 rounded-full border border-[#E63946]/30 animate-pulse"></div><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-hammer h-8 w-8"><path d="m15 12-8.373 8.373a1 1 0 1 1-3-3L12 9"></path><path d="m18 15 4-4"></path><path d="m21.5 11.5-1.914-1.914A2 2 0 0 1 19 8.172V7l-2.26-2.26a6 6 0 0 0-4.202-1.756L9 2.96l.92.82A6.18 6.18 0 0 1 12 8.4V10l2 2h1.172a2 2 0 0 1 1.414.586L18.5 14.5"></path></svg></div><h3 class="font-bold text-xl text-white mb-3 tracking-wide">4. Build &amp; Completion</h3><p class="text-gray-400 font-light leading-relaxed">Our craftsmen execute the work flawlessly and clean up.</p></div></div></div></section><section class="py-24 bg-[#111] border-t border-white/5 relative z-20"><div class="container max-w-4xl"><div class="text-center mb-16"><h2 class="font-heading text-4xl md:text-5xl font-bold mb-6 text-white tracking-tight">Frequently Asked Questions</h2><p class="text-xl text-gray-400 font-light">Common questions from our clients across Central Massachusetts.</p></div><div class="grid grid-cols-1 gap-6"><div class="bg-black p-8 rounded-3xl border border-white/5 hover:border-[#E63946]/30 transition-colors"><h3 class="text-2xl font-bold text-white mb-4">Where is Maverick City Builders located?</h3><p class="text-gray-400 font-light leading-relaxed text-lg">Maverick City Builders is based in Lancaster, MA and serves homeowners throughout Central Massachusetts including Worcester, Leominster, Fitchburg, Clinton, Sterling, Bolton, Hudson, Berlin, Harvard, Marlborough, Stow, Boxborough, Acton, Concord, and Sudbury.</p></div><div class="bg-black p-8 rounded-3xl border border-white/5 hover:border-[#E63946]/30 transition-colors"><h3 class="text-2xl font-bold text-white mb-4">What areas does Maverick City Builders serve?</h3><p class="text-gray-400 font-light leading-relaxed text-lg">Maverick City Builders is headquartered in Lancaster, MA and serves all of Central Massachusetts including Worcester, Leominster, Fitchburg, Clinton, Sterling, Bolton, Hudson, Berlin, Harvard, Marlborough, Stow, Boxborough, Acton, Concord, and Sudbury.</p></div></div></div></section><section class="py-32 mcb-parallax text-white text-center overflow-hidden flex items-center justify-center" style="background-image: url(&quot;https://vibe.filesafe.space/1776285954741479289/assets/40d44aae-b93a-4b05-9a02-b241fa7b4b1f.png&quot;);"><div class="absolute inset-0 bg-[#E63946]/90 mix-blend-multiply z-[1] pointer-events-none"></div><div class="container max-w-4xl relative z-[2]"><div><h2 class="font-heading text-5xl md:text-7xl font-extrabold mb-8 tracking-tight drop-shadow-lg">Ready to Transform Your Home?</h2><p class="text-2xl mb-12 text-white/90 font-light drop-shadow-md">Contact us today. We respond within 24 hours.</p><div class="flex flex-col sm:flex-row gap-6 justify-center"><a class="inline-flex items-center justify-center gap-2 whitespace-nowrap ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 h-11 text-lg px-12 py-8 uppercase tracking-widest font-bold bg-black text-white hover:bg-gray-900 rounded-full shadow-2xl hover:scale-105 transition-transform" href="#/contact">Get Your Free Estimate</a><a href="tel:5086567436" class="inline-flex items-center justify-center gap-2 whitespace-nowrap ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 h-11 text-lg px-12 py-8 uppercase tracking-widest font-bold bg-transparent border-2 border-white text-white hover:bg-white hover:text-[#E63946] rounded-full shadow-2xl hover:scale-105 transition-transform">Call Now</a></div></div></div></section></div></main><footer class="bg-black text-white py-16"><div class="container grid grid-cols-1 md:grid-cols-4 gap-12"><div class="flex flex-col gap-6"><a class="flex items-center gap-2 text-white" href="#/"><img src="/assets/img/logo.webp" alt="Maverick City Builders" width="150" height="64" loading="lazy" class="h-14 md:h-20 w-auto" title="Maverick City Builders Logo"></a><div class="text-gray-400 text-sm leading-relaxed max-w-sm text-justify">Maverick City Builders delivers premium residential construction and remodeling across Massachusetts. Built for homeowners who value quality, precision, and long-term investment in their property.</div></div><div><h2 class="font-heading font-bold text-lg mb-4 text-white">Services</h2><ul class="space-y-3 text-sm text-gray-400"><li><a class="hover:text-[#E63946] transition-colors" href="#/kitchen-remodeling">Kitchen Remodeling</a></li><li><a class="hover:tex
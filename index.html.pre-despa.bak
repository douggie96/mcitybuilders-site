    <!-- MCB Meta Pixel — Contact event on tel: click (delegation, sitewide) -->
    <script>
    (function() {
      document.addEventListener('click', function(e) {
        var target = e.target.closest('a[href^="tel:"]');
        if (!target) return;
        if (typeof window.fbq === 'function') {
          window.fbq('track', 'Contact', {
            content_category: 'phone',
            content_name: target.getAttribute('href').replace('tel:', '').trim()
          });
        }
      }, true);
    })();
    </script>

    <!-- MCB Meta Pixel — ViewContent event on service pages (kitchen / bathroom hubs and area pages) -->
    <script>
    (function() {
      if (typeof window.fbq !== 'function') return;
      var path = window.location.pathname.toLowerCase();
      if (path.indexOf('kitchen') !== -1) {
        window.fbq('track', 'ViewContent', {
          content_category: 'Kitchen Remodeling',
          content_name: path
        });
      } else if (path.indexOf('bathroom') !== -1) {
        window.fbq('track', 'ViewContent', {
          content_category: 'Bathroom Remodeling',
          content_name: path
        });
      }
    })();
    </script>

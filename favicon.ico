    src="https://www.facebook.com/tr?id=1750236342810025&ev=PageView&noscript=1"
    /></noscript>
    <div id="root"></div>
    <!-- Delayed Third-Party Scripts to prioritize LCP and TBT -->
    <script>
      (function() {
        var widgetLoaded = false;
        function loadLeadConnectorWidget() {
          if (widgetLoaded) return;
          widgetLoaded = true;
          var script = document.createElement("script");
          script.src = "https://widgets.leadconnectorhq.com/loader.js";
          script.setAttribute("data-resources-url", "https://widgets.leadconnectorhq.com/chat-widget/loader.js");
          script.setAttribute("data-widget-id", "69e0f4fcea97e06790641e5e");
          script.defer = true;
          document.body.appendChild(script);
          
          ['scroll', 'mousemove', 'touchstart', 'keydown'].forEach(function(e) {
            window.removeEventListener(e, loadLeadConnectorWidget);
          });
        }
        
        // Load on first user interaction
        ['scroll', 'mousemove', 'touchstart', 'keydown'].forEach(function(e) {
          window.addEventListener(e, loadLeadConnectorWidget, { passive: true, once: true });
        });
        
        // Fallback: load after 6 seconds if no interaction occurs
        setTimeout(loadLeadConnectorWidget, 6000);
      })();
    </script>
    <script>
      (function() {
        // MCB tap_to_call event tracking — fires gtag event on any tel: link click sitewide
        document.addEventListener('click', function(e) {
          var target = e.target.closest('a[href^="tel:"]');
          if (!target) return;
          var phone = target.getAttribute('href').replace('tel:', '').trim();
          if (typeof gtag === 'function') {
            gtag('event', 'tap_to_call', {
              phone_number: phone,
              location: window.location.pathname,
              value: 75,
              currency: 'USD'
            });
          }
        }, true);
      })();
    </script>
  </body>
